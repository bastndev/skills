---
import Layout from '../layouts/Layout.astro';
---

<Layout title={`Work · test-4`} projectName="test-4">
  <section class="page">
    <h1>Work</h1>
    <p>A place to showcase projects.</p>
  </section>
</Layout>

<style>
  .page {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
    box-sizing: border-box;
  }
  .page h1 {
    color: var(--color-text);
  }
  .page p {
    color: var(--color-text-muted);
  }
</style>
